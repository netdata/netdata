{
  "jsonSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "title": "Google Secret Manager secretstore configuration.",
    "properties": {
      "mode": {
        "title": "Mode",
        "description": "GCP authentication mode.",
        "type": "string",
        "enum": [
          "metadata",
          "service_account_file"
        ],
        "default": "metadata"
      },
      "timeout": {
        "title": "Timeout",
        "description": "Timeout in seconds for HTTP requests made by this secretstore backend.",
        "type": "number",
        "minimum": 0,
        "default": 3
      }
    },
    "required": [
      "mode"
    ],
    "dependencies": {
      "mode": {
        "oneOf": [
          {
            "properties": {
              "mode": {
                "const": "metadata"
              }
            }
          },
          {
            "properties": {
              "mode": {
                "const": "service_account_file"
              },
              "mode_service_account_file": {
                "title": "Service Account File",
                "description": "Service account file settings used when mode is `service_account_file`.",
                "type": "object",
                "properties": {
                  "path": {
                    "title": "Path",
                    "description": "Path to the service account JSON file.",
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "path"
                ]
              }
            },
            "required": [
              "mode_service_account_file"
            ]
          }
        ]
      }
    }
  },
  "uiSchema": {
    "uiOptions": {
      "fullPage": true
    },
    "mode": {
      "ui:widget": "radio",
      "ui:options": {
        "inline": true
      }
    }
  }
}
