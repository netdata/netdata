{
  "jsonSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "title": "Vault secretstore configuration.",
    "properties": {
      "mode": {
        "title": "Mode",
        "description": "How Vault authentication is provided.",
        "type": "string",
        "enum": [
          "token",
          "token_file"
        ],
        "default": "token"
      },
      "addr": {
        "title": "Address",
        "description": "Vault server address / base URL.",
        "type": "string"
      },
      "namespace": {
        "title": "Namespace",
        "description": "Optional Vault namespace.",
        "type": "string"
      },
      "tls_skip_verify": {
        "title": "Skip TLS verification",
        "description": "Disable TLS certificate verification for Vault requests.",
        "type": "boolean",
        "default": false
      },
      "timeout": {
        "title": "Timeout",
        "description": "Timeout in seconds for HTTP requests made by this secretstore backend.",
        "type": "number",
        "minimum": 0,
        "default": 3
      }
    },
    "required": [
      "mode",
      "addr"
    ],
    "dependencies": {
      "mode": {
        "oneOf": [
          {
            "properties": {
              "mode": {
                "const": "token"
              },
              "mode_token": {
                "title": "Token",
                "description": "Token settings used when mode is `token`.",
                "type": "object",
                "properties": {
                  "token": {
                    "title": "Token",
                    "description": "Vault token value.",
                    "type": "string",
                    "sensitive": true
                  }
                },
                "required": [
                  "token"
                ]
              }
            },
            "required": [
              "mode_token"
            ]
          },
          {
            "properties": {
              "mode": {
                "const": "token_file"
              },
              "mode_token_file": {
                "title": "Token File",
                "description": "Token file settings used when mode is `token_file`.",
                "type": "object",
                "properties": {
                  "path": {
                    "title": "Path",
                    "description": "Path to a file containing the Vault token.",
                    "type": "string"
                  }
                },
                "required": [
                  "path"
                ]
              }
            },
            "required": [
              "mode_token_file"
            ]
          }
        ]
      }
    }
  },
  "uiSchema": {
    "uiOptions": {
      "fullPage": true
    },
    "mode": {
      "ui:widget": "radio",
      "ui:options": {
        "inline": true
      }
    },
    "mode_token": {
      "token": {
        "ui:widget": "password"
      }
    }
  }
}
