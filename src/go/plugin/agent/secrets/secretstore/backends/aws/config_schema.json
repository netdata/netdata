{
  "jsonSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "title": "AWS Secrets Manager secretstore configuration.",
    "properties": {
      "auth_mode": {
        "title": "Auth mode",
        "description": "How AWS credentials are obtained.",
        "type": "string",
        "enum": [
          "env",
          "ecs",
          "imds"
        ],
        "default": "env"
      },
      "region": {
        "title": "Region",
        "description": "AWS region used for Secrets Manager requests.",
        "type": "string"
      }
    },
    "required": [
      "auth_mode",
      "region"
    ]
  },
  "uiSchema": {
    "uiOptions": {
      "fullPage": true
    },
    "auth_mode": {
      "ui:widget": "radio",
      "ui:options": {
        "inline": true
      }
    }
  }
}
