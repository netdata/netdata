{
  "jsonSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "title": "Azure Key Vault secretstore configuration.",
    "properties": {
      "mode": {
        "title": "Mode",
        "description": "Azure authentication mode.",
        "type": "string",
        "enum": [
          "client",
          "managed_identity"
        ],
        "default": "client"
      }
    },
    "required": [
      "mode"
    ],
    "dependencies": {
      "mode": {
        "oneOf": [
          {
            "properties": {
              "mode": {
                "const": "client"
              },
              "mode_client": {
                "title": "Client",
                "description": "Client credentials used when mode is `client`.",
                "type": "object",
                "properties": {
                  "tenant_id": {
                    "title": "Tenant ID",
                    "description": "Azure tenant ID.",
                    "type": "string"
                  },
                  "client_id": {
                    "title": "Client ID",
                    "description": "Azure application / service principal client ID.",
                    "type": "string"
                  },
                  "client_secret": {
                    "title": "Client Secret",
                    "description": "Azure application / service principal client secret.",
                    "type": "string",
                    "sensitive": true
                  }
                },
                "required": [
                  "tenant_id",
                  "client_id",
                  "client_secret"
                ]
              }
            },
            "required": [
              "mode_client"
            ]
          },
          {
            "properties": {
              "mode": {
                "const": "managed_identity"
              },
              "mode_managed_identity": {
                "title": "Managed Identity",
                "description": "Managed identity settings used when mode is `managed_identity`.",
                "type": "object",
                "properties": {
                  "client_id": {
                    "title": "Client ID",
                    "description": "Optional client ID of a user-assigned managed identity.",
                    "type": "string"
                  }
                }
              }
            }
          }
        ]
      }
    }
  },
  "uiSchema": {
    "uiOptions": {
      "fullPage": true
    },
    "mode": {
      "ui:widget": "radio",
      "ui:options": {
        "inline": true
      }
    },
    "mode_client": {
      "client_secret": {
        "ui:widget": "password"
      }
    }
  }
}
