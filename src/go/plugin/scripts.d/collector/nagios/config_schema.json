{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "nagios v2 collector configuration",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "scheduler": {
      "type": "string"
    },
    "vnode": {
      "type": "string"
    },
    "plugin": {
      "type": "string"
    },
    "args": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "arg_values": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "timeout": {
      "type": "string"
    },
    "timeout_state": {
      "type": "string",
      "enum": [
        "critical",
        "warning",
        "unknown"
      ]
    },
    "check_interval": {
      "type": "string"
    },
    "retry_interval": {
      "type": "string"
    },
    "max_check_attempts": {
      "type": "integer",
      "minimum": 1
    },
    "vnode": {
      "type": "string"
    },
    "update_every": {
      "type": "integer",
      "minimum": 1
    },
    "autodetection_retry": {
      "type": "integer",
      "minimum": 1
    },
    "inter_check_jitter": {
      "type": "string"
    },
    "working_directory": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "custom_vars": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "check_period": {
      "type": "string"
    },
    "time_periods": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "alias": {
            "type": "string"
          },
          "exclude": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "rules": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string"
                },
                "days": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "ranges": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "weekday": {
                  "type": "string"
                },
                "nth": {
                  "type": "integer"
                },
                "dates": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "required": [
                "ranges"
              ],
              "additionalProperties": true
            }
          }
        },
        "required": [
          "name",
          "rules"
        ],
        "additionalProperties": true
      }
    },
    "workers": {
      "type": "integer",
      "minimum": 1
    },
    "queue_size": {
      "type": "integer",
      "minimum": 1
    }
  },
  "required": [
    "name",
    "plugin"
  ],
  "additionalProperties": true
}
