{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "scripts.d v2 collector configuration",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "plugin": {
      "type": "string"
    },
    "args": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "timeout": {
      "type": "string"
    },
    "check_interval": {
      "type": "string"
    },
    "retry_interval": {
      "type": "string"
    },
    "max_check_attempts": {
      "type": "integer",
      "minimum": 1
    },
    "vnode": {
      "type": "string"
    },
    "update_every": {
      "type": "integer",
      "minimum": 1
    },
    "scheduler": {
      "type": "string"
    },
    "workers": {
      "type": "integer",
      "minimum": 1
    },
    "queue_size": {
      "type": "integer",
      "minimum": 1
    }
  },
  "additionalProperties": true
}
