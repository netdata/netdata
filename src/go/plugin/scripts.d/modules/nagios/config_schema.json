{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "scripts.d plugin configuration entry",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "Identifier for this configuration shard."
    },
    "vnode": {
      "type": "string",
      "description": "Virtual node GUID/name to associate with all jobs defined in this shard (overridable per job)."
    },
    "update_every": {
      "type": "integer",
      "minimum": 1,
      "description": "Legacy go.d polling interval. Leave unset to rely on Nagios scheduling."
    },
    "autodetection_retry": {
      "type": "integer",
      "minimum": 0,
      "description": "How often (in seconds) go.d retries failed autodetection."
    },
    "executor_workers": {
      "type": "integer",
      "minimum": 1,
      "description": "Maximum concurrent Nagios plugin executions for this shard (default 50)."
    },
    "defaults": {
      "type": "object",
      "description": "Global defaults applied to every job (explicit or directory-generated)",
      "additionalProperties": false,
      "properties": {
        "timeout": {"type": "string", "pattern": "^([0-9]+(\.[0-9]+)?(ns|us|ms|s|m|h|d))+$"},
        "timeout_state": {"type": "string", "enum": ["critical", "warning", "unknown"]},
        "check_interval": {"type": "string", "pattern": "^([0-9]+(\.[0-9]+)?(ns|us|ms|s|m|h|d))+$"},
        "retry_interval": {"type": "string", "pattern": "^([0-9]+(\.[0-9]+)?(ns|us|ms|s|m|h|d))+$"},
        "max_check_attempts": {"type": "integer", "minimum": 1},
        "inter_check_jitter": {"type": "string", "pattern": "^([0-9]+(\.[0-9]+)?(ns|us|ms|s|m|h|d))+$"},
        "working_directory": {"type": "string"},
        "check_period": {"type": "string", "description": "Name of a time_period defined below"}
      }
    },
    "user_macros": {
      "type": "object",
      "description": "Defines $USERn$ macros available to every job in this shard.",
      "additionalProperties": {"type": "string"}
    },
    "jobs": {
      "type": "array",
      "description": "Explicit Nagios job definitions",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": {"type": "string"},
          "vnode": {"type": "string"},
          "plugin": {"type": "string"},
          "args": {"type": "array", "items": {"type": "string"}},
          "arg_values": {"type": "array", "items": {"type": "string"}, "maxItems": 32, "description": "Values bound to $ARGn$ macros"},
          "environment": {"type": "object", "additionalProperties": {"type": "string"}},
          "custom_vars": {"type": "object", "additionalProperties": {"type": "string"}},
          "timeout": {"type": "string", "pattern": "^([0-9]+(\.[0-9]+)?(ns|us|ms|s|m|h|d))+$"},
          "timeout_state": {"type": "string", "enum": ["critical", "warning", "unknown"]},
          "check_interval": {"type": "string", "pattern": "^([0-9]+(\.[0-9]+)?(ns|us|ms|s|m|h|d))+$"},
          "retry_interval": {"type": "string", "pattern": "^([0-9]+(\.[0-9]+)?(ns|us|ms|s|m|h|d))+$"},
          "max_check_attempts": {"type": "integer", "minimum": 1},
          "inter_check_jitter": {"type": "string", "pattern": "^([0-9]+(\.[0-9]+)?(ns|us|ms|s|m|h|d))+$"},
          "working_directory": {"type": "string"},
          "check_period": {"type": "string"}
        },
        "required": ["name", "plugin"]
      }
    },
    "directories": {
      "type": "array",
      "description": "Provision entire directories of Nagios plugins dynamically",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name_prefix": {"type": "string", "description": "Prefix applied to generated job names"},
          "path": {"type": "string", "description": "Directory containing Nagios plugins"},
          "recursive": {"type": "boolean", "description": "Whether to scan subdirectories"},
          "include": {"type": "array", "items": {"type": "string"}, "description": "Glob patterns to include"},
          "exclude": {"type": "array", "items": {"type": "string"}, "description": "Glob patterns to exclude"},
          "args": {"type": "array", "items": {"type": "string"}},
          "environment": {"type": "object", "additionalProperties": {"type": "string"}},
          "custom_vars": {"type": "object", "additionalProperties": {"type": "string"}},
          "defaults": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "timeout": {"type": "string", "pattern": "^([0-9]+(\.[0-9]+)?(ns|us|ms|s|m|h|d))+$"},
              "timeout_state": {"type": "string", "enum": ["critical", "warning", "unknown"]},
              "check_interval": {"type": "string", "pattern": "^([0-9]+(\.[0-9]+)?(ns|us|ms|s|m|h|d))+$"},
              "retry_interval": {"type": "string", "pattern": "^([0-9]+(\.[0-9]+)?(ns|us|ms|s|m|h|d))+$"},
              "max_check_attempts": {"type": "integer", "minimum": 1},
              "inter_check_jitter": {"type": "string", "pattern": "^([0-9]+(\.[0-9]+)?(ns|us|ms|s|m|h|d))+$"},
              "working_directory": {"type": "string"},
              "check_period": {"type": "string"}
            }
          }
        },
        "required": ["path"]
      }
    },
    "time_periods": {
      "type": "array",
      "description": "Time period definitions referenced by jobs",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": {"type": "string"},
          "alias": {"type": "string"},
          "exclude": {"type": "array", "items": {"type": "string"}},
          "rules": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "type": {"type": "string", "enum": ["weekly", "nth_weekday", "date"]},
                "days": {"type": "array", "items": {"type": "string"}},
                "ranges": {"type": "array", "items": {"type": "string", "pattern": "^[0-9]{2}:[0-9]{2}-[0-9]{2}:[0-9]{2}$"}},
                "weekday": {"type": "string"},
                "nth": {"type": "integer", "minimum": 1, "maximum": 5},
                "dates": {"type": "array", "items": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"}}
              },
              "required": ["ranges"]
            }
          }
        },
        "required": ["name", "rules"]
      }
    },
    "logging": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "otlp": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "endpoint": {"type": "string"},
            "timeout": {"type": "string", "pattern": "^([0-9]+(\.[0-9]+)?(ns|us|ms|s|m|h|d))+$"},
            "insecure": {"type": "boolean"},
            "headers": {"type": "object", "additionalProperties": {"type": "string"}},
            "ca_file": {"type": "string"},
            "cert_file": {"type": "string"},
            "key_file": {"type": "string"},
            "server_name": {"type": "string"},
            "insecure_skip_verify": {"type": "boolean"}
          }
        }
      }
    }
  },
  "required": ["name"]
}
