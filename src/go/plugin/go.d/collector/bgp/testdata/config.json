{
  "update_every": 5,
  "autodetection_retry": 60,
  "backend": "frr",
  "socket_path": "/var/run/frr/bgpd.vty",
  "zebra_socket_path": "/var/run/frr/zebra.vty",
  "address": "",
  "api_url": "",
  "server_name": "",
  "tls_ca": "",
  "tls_cert": "",
  "tls_key": "",
  "tls_skip_verify": false,
  "timeout": 2,
  "collect_rib_summaries": false,
  "rib_summary_every": 0,
  "max_families": 10,
  "select_families": {
    "includes": [
      "=default/ipv4/unicast"
    ],
    "excludes": null
  },
  "max_peers": 50,
  "max_vnis": 20,
  "select_vnis": {
    "includes": [
      "=default/172192"
    ],
    "excludes": null
  },
  "deep_peer_prefix_metrics": true,
  "max_deep_queries_per_scrape": 8,
  "select_peers": {
    "includes": [
      "=192.0.2.1"
    ],
    "excludes": [
      "=192.0.2.2"
    ]
  },
  "vnode": "bgp-edge"
}
