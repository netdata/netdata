{
  "jsonSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "AWS CloudWatch collector",
    "type": "object",
    "properties": {
      "update_every": {
        "title": "Update every",
        "description": "Data collection interval, measured in seconds. CloudWatch's minimum period is 60s.",
        "type": "integer",
        "minimum": 60,
        "default": 60
      },
      "autodetection_retry": {
        "title": "Detection retry",
        "description": "Recheck interval in seconds. Zero means no recheck.",
        "type": "integer",
        "minimum": 0,
        "default": 0
      },
      "vnode": {
        "title": "Vnode",
        "description": "Associates this data collection job with a Virtual Node.",
        "type": "string"
      },
      "credentials": {
        "title": "Credential sources",
        "description": "Named sources used by monitored targets. A source uses either the AWS SDK default chain or explicit static/session credentials.",
        "type": "object",
        "minProperties": 1,
        "maxProperties": 64,
        "default": {"sdk_default": {"type": "default"}},
        "propertyNames": {"pattern": "^[a-z][a-z0-9_-]{0,63}$"},
        "patternProperties": {
          "^[a-z][a-z0-9_-]{0,63}$": {
            "oneOf": [
            {
              "title": "AWS SDK default chain",
              "type": "object",
              "properties": {
                "type": {"title": "Type", "const": "default"}
              },
              "required": ["type"]
            },
            {
              "title": "Static or session credentials",
              "type": "object",
              "properties": {
                "type": {"title": "Type", "const": "static"},
                "access_key_id": {"title": "Access key ID", "type": "string", "pattern": "^\\S(?:.*\\S)?$"},
                "secret_access_key": {"title": "Secret access key", "type": "string", "pattern": "^\\S(?:.*\\S)?$", "sensitive": true},
                "session_token": {"title": "Session token", "type": "string", "pattern": "^(?:|\\S(?:.*\\S)?)$", "sensitive": true}
              },
              "required": ["type", "access_key_id", "secret_access_key"]
            }
            ]
          }
        }
      },
      "targets": {
        "title": "Monitored targets",
        "description": "Named AWS identities to monitor. A target uses one credential source directly or uses it to assume one role.",
        "type": "array",
        "minItems": 1,
        "maxItems": 64,
        "default": [{"name": "base", "credentials": "sdk_default"}],
        "items": {
          "type": "object",
          "properties": {
            "name": {"title": "Name", "type": "string", "pattern": "^[a-z][a-z0-9_-]{0,63}$"},
            "credentials": {"title": "Credential source", "type": "string", "pattern": "^[a-z][a-z0-9_-]{0,63}$"},
            "assume_role": {
              "title": "Assume role",
              "type": "object",
              "properties": {
                "role_arn": {"title": "Role ARN", "type": "string", "pattern": "^\\S(?:.*\\S)?$"},
                "external_id": {
                  "title": "External ID",
                  "description": "Value supplied by the role owner when its trust policy requires one. It is not an AWS password or access key.",
                  "type": "string",
                  "pattern": "^(?:|\\S(?:.*\\S)?)$"
                }
              },
              "required": ["role_arn"]
            }
          },
          "required": ["name", "credentials"]
        }
      },
      "rules": {
        "title": "Collection rules",
        "description": "Ordered target, profile, and region selections. Earlier rules own overlapping final metric series; within one rule, earlier targets own overlaps.",
        "type": "array",
        "minItems": 1,
        "maxItems": 256,
        "default": [{"name": "base-defaults", "targets": ["base"], "regions": ["us-east-1"]}],
        "items": {
          "type": "object",
          "properties": {
            "name": {"title": "Name", "type": "string", "pattern": "^[a-z][a-z0-9_-]{0,63}$"},
            "targets": {
              "title": "Targets",
              "description": "Ordered target references. Order breaks overlap ties within this rule.",
              "type": "array",
              "minItems": 1,
              "maxItems": 256,
              "uniqueItems": true,
              "items": {"type": "string", "pattern": "^[a-z][a-z0-9_-]{0,63}$"}
            },
            "profiles": {
              "title": "Profiles",
              "description": "Omit to select default-enabled profiles. Include adds profiles; exclude removes profiles.",
              "type": "object",
              "properties": {
                "defaults": {"title": "Include defaults", "type": "boolean", "default": true},
                "include": {"type": "array", "maxItems": 256, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}},
                "exclude": {"type": "array", "maxItems": 256, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}}
              }
            },
            "regions": {
              "title": "Regions",
              "description": "AWS regions collected by this rule. Profile-specific supported-region restrictions are applied automatically.",
              "type": "array",
              "minItems": 1,
              "maxItems": 256,
              "uniqueItems": true,
              "items": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)+-[0-9]+$"}
            }
          },
          "required": ["name", "targets", "regions"]
        }
      },
      "discovery": {
        "title": "Discovery",
        "type": "object",
        "properties": {
          "refresh_every": {"title": "Refresh interval", "type": "integer", "minimum": 60, "default": 300},
          "recently_active_only": {"title": "Recently active only", "type": "boolean", "default": true}
        }
      },
      "tags": {
        "title": "Resource tag labels",
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {"title": "AWS tag key", "type": "string"},
            "rename": {"title": "Netdata label", "type": "string"}
          },
          "required": ["name"]
        }
      },
      "query_offset": {
        "title": "Query offset",
        "description": "Delay in seconds applied before querying completed CloudWatch periods.",
        "type": "integer",
        "minimum": 0,
        "default": 600
      },
      "timeout": {
        "title": "Timeout",
        "description": "Per-request timeout in seconds.",
        "type": "number",
        "minimum": 0,
        "default": 30
      }
    },
    "required": ["credentials", "targets", "rules"]
  },
  "uiSchema": {
    "uiOptions": {"fullPage": true},
    "timeout": {"ui:help": "Accepts decimals for sub-second values."}
  }
}
