{
  "jsonSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Azure Monitor collector configuration.",
    "type": "object",
    "properties": {
      "update_every": {
        "title": "Update every",
        "description": "Data collection interval, in seconds.",
        "type": "integer",
        "minimum": 60,
        "default": 60
      },
      "autodetection_retry": {
        "title": "Detection retry",
        "description": "Recheck interval in seconds. Zero disables retries.",
        "type": "integer",
        "minimum": 0,
        "default": 0
      },
      "subscription_ids": {
        "title": "Subscription IDs",
        "description": "Azure subscription IDs.",
        "type": "array",
        "items": {
          "type": "string"
        },
        "minItems": 1
      },
      "cloud": {
        "title": "Azure cloud",
        "description": "Azure cloud environment.",
        "type": "string",
        "enum": [
          "public",
          "government",
          "china"
        ],
        "default": "public"
      },
      "discovery": {
        "title": "Discovery",
        "type": "object",
        "properties": {
          "refresh_every": {
            "title": "Discovery every",
            "description": "Resource discovery refresh interval, in seconds. Set to 0 to disable periodic runtime rediscovery after bootstrap.",
            "type": "integer",
            "minimum": 0,
            "default": 300
          },
          "mode": {
            "title": "Discovery mode",
            "description": "How candidate Azure resources are selected.",
            "type": "string",
            "enum": [
              "filters",
              "query"
            ],
            "default": "filters"
          }
        },
        "dependencies": {
          "mode": {
            "oneOf": [
              {
                "properties": {
                  "mode": {
                    "const": "filters"
                  },
                  "mode_filters": {
                    "title": "Structured filters",
                    "type": "object",
                    "properties": {
                      "resource_groups": {
                        "title": "Resource groups",
                        "description": "Optional list of Azure resource groups to include.",
                        "type": "array",
                        "items": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "regions": {
                        "title": "Regions",
                        "description": "Optional list of Azure regions to include.",
                        "type": "array",
                        "items": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "tags": {
                        "title": "Tags",
                        "description": "Optional tag filters. Keys map to one or more accepted values.",
                        "type": "object",
                        "additionalProperties": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          },
                          "minItems": 1
                        }
                      }
                    }
                  }
                }
              },
              {
                "properties": {
                  "mode": {
                    "const": "query"
                  },
                  "mode_query": {
                    "title": "Custom query",
                    "type": "object",
                    "properties": {
                      "kql": {
                        "title": "Azure Resource Graph KQL",
                        "description": "Custom Azure Resource Graph query.",
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "required": [
                      "kql"
                    ]
                  }
                },
                "required": [
                  "mode_query"
                ]
              }
            ]
          }
        }
      },
      "profiles": {
        "title": "Profiles",
        "type": "object",
        "properties": {
          "mode": {
            "title": "Profiles mode",
            "description": "How metric profiles are selected.",
            "type": "string",
            "enum": [
              "auto",
              "exact",
              "combined"
            ],
            "default": "auto"
          }
        },
        "dependencies": {
          "mode": {
            "oneOf": [
              {
                "properties": {
                  "mode": {
                    "const": "auto"
                  },
                  "mode_auto": {
                    "title": "Auto profile overrides",
                    "type": "object",
                    "properties": {
                      "entries": {
                        "title": "Profile entries",
                        "description": "Optional per-profile overrides applied only to profiles that auto-activate at bootstrap. Unmatched entries stay dormant.",
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "name": {
                              "title": "Profile basename",
                              "description": "Canonical profile basename. Must be lowercase letters, digits, or underscores and start with a letter.",
                              "type": "string",
                              "pattern": "^[a-z][a-z0-9_]*$"
                            },
                            "filters": {
                              "title": "Filters",
                              "description": "Optional per-profile resource filters that narrow the globally discovered set for this profile.",
                              "type": "object",
                              "properties": {
                                "resource_groups": {
                                  "title": "Resource groups",
                                  "type": "array",
                                  "items": {
                                    "type": "string",
                                    "minLength": 1
                                  }
                                },
                                "regions": {
                                  "title": "Regions",
                                  "type": "array",
                                  "items": {
                                    "type": "string",
                                    "minLength": 1
                                  }
                                },
                                "tags": {
                                  "title": "Tags",
                                  "description": "Optional tag filters for this profile. Supported only when `discovery.mode` is `filters`; in `query` mode, encode per-profile tag filtering in the KQL.",
                                  "type": "object",
                                  "additionalProperties": {
                                    "type": "array",
                                    "items": {
                                      "type": "string",
                                      "minLength": 1
                                    },
                                    "minItems": 1
                                  }
                                }
                              }
                            }
                          },
                          "required": [
                            "name"
                          ]
                        }
                      }
                    }
                  }
                }
              },
              {
                "properties": {
                  "mode": {
                    "const": "exact"
                  },
                  "mode_exact": {
                    "title": "Exact profiles",
                    "type": "object",
                    "properties": {
                      "entries": {
                        "title": "Profile entries",
                        "description": "Explicit profile entries used by `exact` mode.",
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "name": {
                              "title": "Profile basename",
                              "description": "Canonical profile basename. Must be lowercase letters, digits, or underscores and start with a letter.",
                              "type": "string",
                              "pattern": "^[a-z][a-z0-9_]*$"
                            },
                            "filters": {
                              "title": "Filters",
                              "description": "Optional per-profile resource filters that narrow the globally discovered set for this profile.",
                              "type": "object",
                              "properties": {
                                "resource_groups": {
                                  "title": "Resource groups",
                                  "type": "array",
                                  "items": {
                                    "type": "string",
                                    "minLength": 1
                                  }
                                },
                                "regions": {
                                  "title": "Regions",
                                  "type": "array",
                                  "items": {
                                    "type": "string",
                                    "minLength": 1
                                  }
                                },
                                "tags": {
                                  "title": "Tags",
                                  "description": "Optional tag filters for this profile. Supported only when `discovery.mode` is `filters`; in `query` mode, encode per-profile tag filtering in the KQL.",
                                  "type": "object",
                                  "additionalProperties": {
                                    "type": "array",
                                    "items": {
                                      "type": "string",
                                      "minLength": 1
                                    },
                                    "minItems": 1
                                  }
                                }
                              }
                            }
                          },
                          "required": [
                            "name"
                          ]
                        }
                      }
                    },
                    "required": [
                      "entries"
                    ]
                  }
                },
                "required": [
                  "mode_exact"
                ]
              },
              {
                "properties": {
                  "mode": {
                    "const": "combined"
                  },
                  "mode_combined": {
                    "title": "Combined profiles",
                    "type": "object",
                    "properties": {
                      "entries": {
                        "title": "Profile entries",
                        "description": "Explicit profile entries merged with auto-discovered profiles in `combined` mode.",
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "name": {
                              "title": "Profile basename",
                              "description": "Canonical profile basename. Must be lowercase letters, digits, or underscores and start with a letter.",
                              "type": "string",
                              "pattern": "^[a-z][a-z0-9_]*$"
                            },
                            "filters": {
                              "title": "Filters",
                              "description": "Optional per-profile resource filters that narrow the globally discovered set for this profile.",
                              "type": "object",
                              "properties": {
                                "resource_groups": {
                                  "title": "Resource groups",
                                  "type": "array",
                                  "items": {
                                    "type": "string",
                                    "minLength": 1
                                  }
                                },
                                "regions": {
                                  "title": "Regions",
                                  "type": "array",
                                  "items": {
                                    "type": "string",
                                    "minLength": 1
                                  }
                                },
                                "tags": {
                                  "title": "Tags",
                                  "description": "Optional tag filters for this profile. Supported only when `discovery.mode` is `filters`; in `query` mode, encode per-profile tag filtering in the KQL.",
                                  "type": "object",
                                  "additionalProperties": {
                                    "type": "array",
                                    "items": {
                                      "type": "string",
                                      "minLength": 1
                                    },
                                    "minItems": 1
                                  }
                                }
                              }
                            }
                          },
                          "required": [
                            "name"
                          ]
                        }
                      }
                    },
                    "required": [
                      "entries"
                    ]
                  }
                },
                "required": [
                  "mode_combined"
                ]
              }
            ]
          }
        }
      },
      "query_offset": {
        "title": "Query offset",
        "description": "Minimum seconds to shift metric queries into the past; slower time-grain batches may use a larger effective offset automatically.",
        "type": "integer",
        "minimum": 60,
        "default": 180
      },
      "timeout": {
        "title": "Timeout",
        "description": "Timeout for Azure Resource Graph and Azure Monitor API requests, in seconds.",
        "type": "number",
        "minimum": 0,
        "default": 30
      },
      "limits": {
        "title": "Limits",
        "type": "object",
        "properties": {
          "max_concurrency": {
            "title": "Max concurrency",
            "description": "Maximum concurrent Azure Monitor batch requests.",
            "type": "integer",
            "minimum": 1,
            "maximum": 64,
            "default": 4
          },
          "max_batch_resources": {
            "title": "Max resources per batch",
            "description": "Maximum resource IDs per batch API call.",
            "type": "integer",
            "minimum": 1,
            "maximum": 50,
            "default": 50
          },
          "max_metrics_per_query": {
            "title": "Max metrics per query",
            "description": "Maximum metric names per batch API call.",
            "type": "integer",
            "minimum": 1,
            "maximum": 20,
            "default": 20
          }
        }
      },
      "auth": {
        "title": "Authentication",
        "description": "Azure authentication mode and credentials.",
        "type": "object",
        "properties": {
          "mode": {
            "title": "Mode",
            "description": "Azure AD credential mode.",
            "type": "string",
            "enum": [
              "service_principal",
              "managed_identity",
              "default"
            ],
            "default": "default"
          }
        },
        "dependencies": {
          "mode": {
            "oneOf": [
              {
                "properties": {
                  "mode": {
                    "const": "service_principal"
                  },
                  "mode_service_principal": {
                    "title": "Service Principal",
                    "description": "Service principal settings used when mode is `service_principal`.",
                    "type": "object",
                    "properties": {
                      "tenant_id": {
                        "title": "Tenant ID",
                        "description": "Azure tenant ID.",
                        "type": "string"
                      },
                      "client_id": {
                        "title": "Client ID",
                        "description": "Service principal client ID.",
                        "type": "string"
                      },
                      "client_secret": {
                        "title": "Client Secret",
                        "description": "Service principal client secret.",
                        "type": "string",
                        "sensitive": true
                      }
                    },
                    "required": [
                      "tenant_id",
                      "client_id",
                      "client_secret"
                    ]
                  }
                },
                "required": [
                  "mode_service_principal"
                ]
              },
              {
                "properties": {
                  "mode": {
                    "const": "managed_identity"
                  },
                  "mode_managed_identity": {
                    "title": "Managed Identity",
                    "description": "Managed identity settings used when mode is `managed_identity`.",
                    "type": "object",
                    "properties": {
                      "client_id": {
                        "title": "Client ID",
                        "description": "Optional client ID of a user-assigned managed identity.",
                        "type": "string"
                      }
                    }
                  }
                }
              },
              {
                "properties": {
                  "mode": {
                    "const": "default"
                  }
                }
              }
            ]
          }
        },
        "required": [
          "mode"
        ]
      },
      "vnode": {
        "title": "Virtual Node",
        "description": "Associates this data collection job with a Virtual Node.",
        "type": "string"
      }
    },
    "required": [
      "subscription_ids",
      "auth"
    ]
  },
  "uiSchema": {
    "uiOptions": {
      "fullPage": true
    },
    "subscription_ids": {
      "ui:listFlavour": "list",
      "ui:help": "Add one Azure subscription ID per row. This job will monitor resources across all listed subscriptions.",
      "items": {
        "ui:help": "Azure subscription ID.",
        "ui:placeholder": "00000000-0000-0000-0000-000000000000"
      }
    },
    "cloud": {
      "ui:help": "Select the Azure cloud environment that contains the subscriptions you want to monitor.",
      "ui:widget": "radio",
      "ui:options": {
        "inline": true
      }
    },
    "discovery": {
      "mode": {
        "ui:help": "Choose how the collector finds candidate Azure resources: `filters` uses structured subscription/resource filters, while `query` runs your custom Azure Resource Graph KQL.",
        "ui:widget": "radio",
        "ui:options": {
          "inline": true
        }
      },
      "mode_filters": {
        "resource_groups": {
          "ui:listFlavour": "list",
          "ui:help": "Optional list of Azure resource groups to include. Leave empty to include matching resources from all resource groups.",
          "items": {
            "ui:help": "Azure resource group name.",
            "ui:placeholder": "rg-production"
          }
        },
        "regions": {
          "ui:listFlavour": "list",
          "ui:help": "Optional list of Azure regions to include. Leave empty to include matching resources from all regions.",
          "items": {
            "ui:help": "Azure region name.",
            "ui:placeholder": "eastus"
          }
        },
        "tags": {
          "ui:help": "Optional tag filters. Add a tag key and then provide one or more accepted values for that key. Tag keys are matched case-insensitively and values are matched case-sensitively.",
          "additionalProperties": {
            "ui:listFlavour": "list",
            "ui:help": "Add one or more accepted values for this tag key.",
            "items": {
              "ui:help": "Allowed value for the selected tag key.",
              "ui:placeholder": "prod"
            }
          }
        }
      },
      "mode_query": {
        "kql": {
          "ui:help": "Provide a custom Azure Resource Graph KQL query. The result must include resource `id`, `name`, `type`, `resourceGroup`, and `location`.",
          "ui:placeholder": "resources | where tags.env == 'prod' | project id, name, type, resourceGroup, location",
          "ui:widget": "textarea"
        }
      }
    },
    "profiles": {
      "mode": {
        "ui:help": "Choose how metric profiles are activated: `auto` enables profiles for discovered resource types, `exact` uses only the listed profile entries, and `combined` merges both.",
        "ui:widget": "radio",
        "ui:options": {
          "inline": true
        }
      },
      "mode_auto": {
        "entries": {
          "ui:listFlavour": "list",
          "ui:help": "Optional per-profile overrides applied only to profiles that auto-activate at bootstrap.",
          "items": {
            "name": {
              "ui:help": "Canonical profile basename.",
              "ui:placeholder": "sql_database"
            },
            "filters": {
              "resource_groups": {
                "ui:listFlavour": "list"
              },
              "regions": {
                "ui:listFlavour": "list"
              },
              "tags": {
                "ui:help": "Only supported when `discovery.mode` is `filters`. In `query` mode, encode per-profile tag filtering in the KQL.",
                "additionalProperties": {
                  "ui:listFlavour": "list"
                }
              }
            }
          }
        }
      },
      "mode_exact": {
        "entries": {
          "ui:listFlavour": "list",
          "ui:help": "Add explicit profile entries for `exact` mode.",
          "items": {
            "name": {
              "ui:help": "Canonical profile basename.",
              "ui:placeholder": "sql_database"
            },
            "filters": {
              "resource_groups": {
                "ui:listFlavour": "list"
              },
              "regions": {
                "ui:listFlavour": "list"
              },
              "tags": {
                "ui:help": "Only supported when `discovery.mode` is `filters`. In `query` mode, encode per-profile tag filtering in the KQL.",
                "additionalProperties": {
                  "ui:listFlavour": "list"
                }
              }
            }
          }
        }
      },
      "mode_combined": {
        "entries": {
          "ui:listFlavour": "list",
          "ui:help": "Add explicit profile entries to merge with auto-discovered profiles in `combined` mode.",
          "items": {
            "name": {
              "ui:help": "Canonical profile basename.",
              "ui:placeholder": "sql_database"
            },
            "filters": {
              "resource_groups": {
                "ui:listFlavour": "list"
              },
              "regions": {
                "ui:listFlavour": "list"
              },
              "tags": {
                "ui:help": "Only supported when `discovery.mode` is `filters`. In `query` mode, encode per-profile tag filtering in the KQL.",
                "additionalProperties": {
                  "ui:listFlavour": "list"
                }
              }
            }
          }
        }
      }
    },
    "timeout": {
      "ui:help": "Accepts decimals for sub-second granularity (for example, `0.5` for 500ms)."
    },
    "limits": {},
    "auth": {
      "mode": {
        "ui:help": "Choose how Netdata gets Azure credentials: `service_principal` uses explicit app credentials, `managed_identity` uses an attached Azure identity, and `default` uses the Azure SDK credential chain.",
        "ui:widget": "radio",
        "ui:options": {
          "inline": true
        }
      },
      "mode_service_principal": {
        "tenant_id": {
          "ui:help": "Azure tenant ID for the service principal.",
          "ui:placeholder": "00000000-0000-0000-0000-000000000000"
        },
        "client_id": {
          "ui:help": "Azure client ID of the service principal application.",
          "ui:placeholder": "00000000-0000-0000-0000-000000000000"
        },
        "client_secret": {
          "ui:help": "Client secret for the Azure service principal.",
          "ui:placeholder": "paste-client-secret-here",
          "ui:widget": "password"
        }
      },
      "mode_managed_identity": {
        "client_id": {
          "ui:help": "Optional client ID of a user-assigned managed identity. Leave empty to use the system-assigned managed identity.",
          "ui:placeholder": "00000000-0000-0000-0000-000000000000"
        }
      }
    },
    "vnode": {
      "ui:help": "Optional virtual node name used to group charts from this job under a specific Netdata virtual node.",
      "ui:placeholder": "To use this option, first create a Virtual Node and then reference its name here."
    },
    "ui:flavour": "tabs",
    "ui:options": {
      "tabs": [
        {
          "title": "Base",
          "fields": [
            "subscription_ids",
            "cloud",
            "update_every",
            "autodetection_retry",
            "query_offset",
            "timeout",
            "vnode"
          ]
        },
        {
          "title": "Auth",
          "fields": [
            "auth"
          ]
        },
        {
          "title": "Discovery",
          "fields": [
            "discovery"
          ]
        },
        {
          "title": "Profiles",
          "fields": [
            "profiles"
          ]
        },
        {
          "title": "Limits",
          "fields": [
            "limits"
          ]
        }
      ]
    }
  }
}
