{
  "jsonSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Azure Monitor collector configuration.",
    "type": "object",
    "properties": {
      "update_every": {
        "title": "Update every",
        "description": "Data collection interval, in seconds.",
        "type": "integer",
        "minimum": 60,
        "default": 60
      },
      "autodetection_retry": {
        "title": "Detection retry",
        "description": "Recheck interval in seconds. Zero disables retries.",
        "type": "integer",
        "minimum": 0,
        "default": 0
      },
      "subscription_ids": {
        "title": "Subscription IDs",
        "description": "Azure subscription IDs.",
        "type": "array",
        "items": {
          "type": "string"
        },
        "minItems": 1
      },
      "cloud": {
        "title": "Azure cloud",
        "description": "Azure cloud environment.",
        "type": "string",
        "enum": [
          "public",
          "government",
          "china"
        ],
        "default": "public"
      },
      "discovery": {
        "title": "Discovery",
        "type": "object",
        "properties": {
          "refresh_every": {
            "title": "Discovery every",
            "description": "Resource discovery refresh interval, in seconds. Set to 0 to disable periodic runtime rediscovery after bootstrap.",
            "type": "integer",
            "minimum": 0,
            "default": 300
          },
          "mode": {
            "title": "Discovery mode",
            "description": "How candidate Azure resources are selected.",
            "type": "string",
            "enum": [
              "filters",
              "query"
            ],
            "default": "filters"
          }
        },
        "dependencies": {
          "mode": {
            "oneOf": [
              {
                "properties": {
                  "mode": {
                    "const": "filters"
                  },
                  "mode_filters": {
                    "title": "Structured filters",
                    "type": "object",
                    "properties": {
                      "resource_groups": {
                        "title": "Resource groups",
                        "description": "Optional list of Azure resource groups to include.",
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "regions": {
                        "title": "Regions",
                        "description": "Optional list of Azure regions to include.",
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "tags": {
                        "title": "Tags",
                        "description": "Optional tag filters. Keys map to one or more accepted values.",
                        "type": "object",
                        "additionalProperties": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          },
                          "minItems": 1
                        }
                      }
                    }
                  }
                }
              },
              {
                "properties": {
                  "mode": {
                    "const": "query"
                  },
                  "mode_query": {
                    "title": "Custom query",
                    "type": "object",
                    "properties": {
                      "kql": {
                        "title": "Azure Resource Graph KQL",
                        "description": "Custom Azure Resource Graph query.",
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "required": [
                      "kql"
                    ]
                  }
                },
                "required": [
                  "mode_query"
                ]
              }
            ]
          }
        }
      },
      "profiles": {
        "title": "Profiles",
        "type": "object",
        "properties": {
          "mode": {
            "title": "Profiles mode",
            "description": "How metric profiles are selected.",
            "type": "string",
            "enum": [
              "auto",
              "exact",
              "combined"
            ],
            "default": "auto"
          }
        },
        "dependencies": {
          "mode": {
            "oneOf": [
              {
                "properties": {
                  "mode": {
                    "const": "auto"
                  }
                }
              },
              {
                "properties": {
                  "mode": {
                    "const": "exact"
                  },
                  "mode_exact": {
                    "title": "Exact profiles",
                    "type": "object",
                    "properties": {
                      "names": {
                        "title": "Profile Names",
                        "description": "Explicit profile names used by `exact` mode. Matching is case-insensitive.",
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    },
                    "required": [
                      "names"
                    ]
                  }
                },
                "required": [
                  "mode_exact"
                ]
              },
              {
                "properties": {
                  "mode": {
                    "const": "combined"
                  },
                  "mode_combined": {
                    "title": "Combined profiles",
                    "type": "object",
                    "properties": {
                      "names": {
                        "title": "Profile Names",
                        "description": "Explicit profile names merged with auto-discovered profiles in `combined` mode. Matching is case-insensitive.",
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    },
                    "required": [
                      "names"
                    ]
                  }
                },
                "required": [
                  "mode_combined"
                ]
              }
            ]
          }
        }
      },
      "query_offset": {
        "title": "Query offset",
        "description": "How many seconds to shift queries into the past to avoid partial Azure Monitor windows.",
        "type": "integer",
        "minimum": 60,
        "default": 180
      },
      "timeout": {
        "title": "Timeout",
        "description": "Timeout for Azure Resource Graph and Azure Monitor API requests, in seconds.",
        "type": "number",
        "minimum": 0,
        "default": 30
      },
      "limits": {
        "title": "Limits",
        "type": "object",
        "properties": {
          "max_concurrency": {
            "title": "Max concurrency",
            "description": "Maximum concurrent Azure Monitor batch requests.",
            "type": "integer",
            "minimum": 1,
            "maximum": 64,
            "default": 4
          },
          "max_batch_resources": {
            "title": "Max resources per batch",
            "description": "Maximum resource IDs per batch API call.",
            "type": "integer",
            "minimum": 1,
            "maximum": 50,
            "default": 50
          },
          "max_metrics_per_query": {
            "title": "Max metrics per query",
            "description": "Maximum metric names per batch API call.",
            "type": "integer",
            "minimum": 1,
            "maximum": 20,
            "default": 20
          }
        }
      },
      "auth": {
        "title": "Authentication",
        "description": "Azure authentication mode and credentials.",
        "type": "object",
        "properties": {
          "mode": {
            "title": "Mode",
            "description": "Azure AD credential mode.",
            "type": "string",
            "enum": [
              "service_principal",
              "managed_identity",
              "default"
            ],
            "default": "default"
          }
        },
        "dependencies": {
          "mode": {
            "oneOf": [
              {
                "properties": {
                  "mode": {
                    "const": "service_principal"
                  },
                  "mode_service_principal": {
                    "title": "Service Principal",
                    "description": "Service principal settings used when mode is `service_principal`.",
                    "type": "object",
                    "properties": {
                      "tenant_id": {
                        "title": "Tenant ID",
                        "description": "Azure tenant ID.",
                        "type": "string"
                      },
                      "client_id": {
                        "title": "Client ID",
                        "description": "Service principal client ID.",
                        "type": "string"
                      },
                      "client_secret": {
                        "title": "Client Secret",
                        "description": "Service principal client secret.",
                        "type": "string",
                        "sensitive": true
                      }
                    },
                    "required": [
                      "tenant_id",
                      "client_id",
                      "client_secret"
                    ]
                  }
                },
                "required": [
                  "mode_service_principal"
                ]
              },
              {
                "properties": {
                  "mode": {
                    "const": "managed_identity"
                  },
                  "mode_managed_identity": {
                    "title": "Managed Identity",
                    "description": "Managed identity settings used when mode is `managed_identity`.",
                    "type": "object",
                    "properties": {
                      "client_id": {
                        "title": "Client ID",
                        "description": "Optional client ID of a user-assigned managed identity.",
                        "type": "string"
                      }
                    }
                  }
                }
              },
              {
                "properties": {
                  "mode": {
                    "const": "default"
                  }
                }
              }
            ]
          }
        },
        "required": [
          "mode"
        ]
      },
      "vnode": {
        "title": "Virtual Node",
        "description": "Associates this data collection job with a Virtual Node.",
        "type": "string"
      }
    },
    "required": [
      "subscription_ids",
      "auth"
    ]
  },
  "uiSchema": {
    "uiOptions": {
      "fullPage": true
    },
    "subscription_ids": {
      "ui:listFlavour": "list"
    },
    "cloud": {
      "ui:widget": "radio",
      "ui:options": {
        "inline": true
      }
    },
    "discovery": {
      "mode": {
        "ui:widget": "radio",
        "ui:options": {
          "inline": true
        }
      },
      "mode_filters": {
        "resource_groups": {
          "ui:listFlavour": "list"
        },
        "regions": {
          "ui:listFlavour": "list"
        }
      },
      "mode_query": {
        "kql": {
          "ui:widget": "textarea"
        }
      }
    },
    "profiles": {
      "mode": {
        "ui:widget": "radio",
        "ui:options": {
          "inline": true
        }
      },
      "mode_exact": {
        "names": {
          "ui:listFlavour": "list"
        }
      },
      "mode_combined": {
        "names": {
          "ui:listFlavour": "list"
        }
      }
    },
    "timeout": {
      "ui:help": "Accepts decimals for sub-second granularity (for example, `0.5` for 500ms)."
    },
    "limits": {},
    "auth": {
      "mode": {
        "ui:widget": "radio",
        "ui:options": {
          "inline": true
        }
      },
      "mode_service_principal": {
        "client_secret": {
          "ui:widget": "password"
        }
      }
    },
    "ui:flavour": "tabs",
    "ui:options": {
      "tabs": [
        {
          "title": "Base",
          "fields": [
            "subscription_ids",
            "cloud",
            "update_every",
            "autodetection_retry",
            "query_offset",
            "timeout",
            "vnode"
          ]
        },
        {
          "title": "Auth",
          "fields": [
            "auth"
          ]
        },
        {
          "title": "Discovery",
          "fields": [
            "discovery"
          ]
        },
        {
          "title": "Profiles",
          "fields": [
            "profiles"
          ]
        },
        {
          "title": "Limits",
          "fields": [
            "limits"
          ]
        }
      ]
    }
  }
}
