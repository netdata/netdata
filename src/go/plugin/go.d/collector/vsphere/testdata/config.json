{
  "vnode": "ok",
  "update_every": 123,
  "autodetection_retry": 123,
  "url": "ok",
  "body": "ok",
  "method": "ok",
  "headers": {
    "ok": "ok"
  },
  "username": "ok",
  "password": "ok",
  "bearer_token_file": "ok",
  "proxy_url": "ok",
  "proxy_username": "ok",
  "proxy_password": "ok",
  "timeout": 123.123,
  "not_follow_redirects": true,
  "tls_ca": "ok",
  "tls_cert": "ok",
  "tls_key": "ok",
  "tls_skip_verify": true,
  "force_http2": true,
  "discovery_interval": 123.123,
  "tag_categories": [
    "Environment",
    "Business*"
  ],
  "custom_attributes": [
    "Owner",
    "Cost Center"
  ],
  "collect_vm_disks": true,
  "collect_vm_disk_performance": true,
  "collect_datastore_clusters": true,
  "datastore_cluster_include": [
    "/*"
  ],
  "vm_disk_include": [
    "Hard*",
    "key:2000"
  ],
  "collect_vm_nic_performance": true,
  "vm_nic_include": [
    "Network adapter*",
    "interface:4000"
  ],
  "collect_host_nic_performance": true,
  "host_nic_include": [
    "vmnic*",
    "interface:vmnic0"
  ],
  "collect_host_disk_performance": true,
  "host_disk_include": [
    "naa.*",
    "instance:naa.123"
  ],
  "collect_host_storage_adapter_performance": true,
  "host_storage_adapter_include": [
    "vmhba*",
    "adapter:vmhba0"
  ],
  "collect_host_storage_path_performance": true,
  "host_storage_path_include": [
    "vmhba*:C0:T0:L0",
    "path:vmhba0:C0:T0:L0"
  ],
  "collect_host_cpu_instance_performance": true,
  "host_cpu_instance_include": [
    "0",
    "cpu:1"
  ],
  "collect_power_metrics": true,
  "collect_vsan": true,
  "vsan_cluster_include": [
    "/DC1/Cluster*",
    "vsan_uuid:cluster-uuid"
  ],
  "vsan_host_include": [
    "/DC1/Cluster*/Host*",
    "vsan_node_uuid:host-uuid"
  ],
  "vsan_vm_include": [
    "/DC1/Cluster*/Host*/VM*",
    "instance_uuid:vm-uuid"
  ],
  "collect_network_topology": true,
  "host_include": [
    "ok"
  ],
  "vm_include": [
    "ok"
  ],
  "datastore_include": [
    "ok"
  ],
  "cluster_include": [
    "ok"
  ]
}
