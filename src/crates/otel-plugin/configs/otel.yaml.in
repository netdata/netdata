# OpenTelemetry Plugin Configuration
# This file configures the OpenTelemetry metrics and logs ingestion for Netdata
#
# To customize, run: edit-config otel.yaml
# Only include the fields you want to change — missing fields keep their defaults.

endpoint:
  # gRPC endpoint to listen on for OpenTelemetry data
  path: "127.0.0.1:4317"

  # Path to TLS certificate file (enables TLS when provided)
  tls_cert_path: null

  # Path to TLS private key file (required when TLS certificate is provided)
  tls_key_path: null

  # Path to TLS CA certificate file for client authentication (optional)
  tls_ca_cert_path: null

metrics:
  # Directory with configuration files for mapping OTEL metrics to Netdata charts
  chart_configs_dir: @configdir_POST@/otel.d/v1/metrics

  # Collection interval in seconds (1–3600). Defines the Netdata chart update frequency.
  interval_secs: 10

  # Grace period in seconds. After the last data point, the plugin waits this long
  # before gap-filling. When interval_secs is overridden, this auto-derives as
  # 5 * interval_secs unless explicitly set.
  grace_period_secs: 60

  # Expiry duration in seconds. Charts with no data for this long are removed.
  expiry_duration_secs: 900

  # Maximum number of new charts that can be created per gRPC request.
  # Limits cardinality explosion from high-cardinality label combinations.
  max_new_charts_per_request: 100

# Single mandatory root directory for all signal storage. The plugin derives
# every per-signal directory from it, so there is one place to relocate storage:
#   {base_dir}/logs/{wal,index,catalog}     — logs WAL, index, catalog files
#   {base_dir}/traces/{wal,index,catalog}   — traces WAL, index, catalog files
#   {base_dir}/<signal>/remote-read         — per-signal remote-read cache
#   {base_dir}/shared/seq_highwater         — cross-signal sequence high-water
base_dir: @logdir_POST@/otel/v1

storage:
  # Remote object storage is GLOBAL: one on/off switch and one backend for the
  # whole plugin. Every signal uploads to the same backend under its own
  # v1/<signal>/... key prefix.

  # Whether to upload SFST and catalog files to remote object storage.
  enabled: false

  # OpenDAL URI for the remote storage backend. The scheme selects the
  # backend; all NON-SECRET backend options go in the query string (OpenDAL
  # parses them — see https://docs.rs/opendal). Built-in schemes: fs, s3.
  # Examples:
  #   fs:///var/lib/netdata/otel/remote
  #   s3://bucket/prefix?region=us-east-1
  #   s3://bucket/prefix?region=us-east-1&endpoint=https://minio.example:9000
  uri: "fs://@logdir_POST@/otel/v1/remote"

  # CREDENTIALS ARE NEVER PUT IN THIS FILE. Do not place access keys, secret
  # keys, SAS tokens, or account keys in the URI or anywhere in otel.yaml.
  # Credentials are loaded by OpenDAL from the netdata process environment and
  # the cloud-standard locations, exactly like any other tool on the host:
  #   - S3:    AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY (and AWS_SESSION_TOKEN),
  #            ~/.aws/{config,credentials}, EC2 instance role / IMDS, IRSA.
  #   - GCS:   GOOGLE_APPLICATION_CREDENTIALS (path to a service-account JSON),
  #            gcloud well-known location, GCE VM metadata. (build with services-gcs)
  #   - Azure: AZURE_STORAGE_ACCOUNT / _KEY / _SAS_TOKEN, managed identity.
  #            (build with services-azblob)
  # Set these in the environment of the netdata service (e.g. a systemd
  # EnvironmentFile with 0600 perms) — the plugin inherits it. On a cloud VM
  # with an attached role, nothing needs to be set at all.
  #
  # On startup (when enabled) the plugin probes the backend and logs, under the
  # systemd-journal identifier "otel-plugin/ledger", either
  #   "remote storage reachable and credentials accepted"  or
  #   "remote storage enabled but unreachable or misconfigured: <error>".
  # The plugin redacts the URI to its scheme (e.g. "s3://[redacted]") in its own
  # startup config log. It does NOT sanitize errors raised by the storage library,
  # which may quote the URI — so never put a secret in it (see credentials below).
  #
  # Read cache: to answer a query over SFSTs that local retention has already
  # evicted, the plugin fetches them back from remote storage into a bounded
  # local cache and memory-maps them like any local file. The cache lives at
  # {base_dir}/<signal>/remote-read (derived, per signal; created 0700) on
  # locally-attached storage and is capped by size.
  #
  # Hard size cap for the read cache (e.g. "4GB", "512MB"). Default "4GiB".
  # A query whose evicted footprint exceeds this cap is rejected with a message
  # asking to narrow the time window or stream filter.
  # read_cache_max_size: "4GiB"

auth:
  # GLOBAL tenant policy (one for the whole plugin). Whether to require tenant
  # identification via the X-Scope-OrgID gRPC metadata header. When false, all
  # data routes to a "default" tenant.
  enabled: false

# Per-signal tuning. Directories are derived from base_dir; storage and auth
# are global (above). Each signal carries only its own rotation/retention/crc
# tuning.
logs:
  wal:
    # Whether to compute CRC32 checksums per frame.
    crc_enabled: true

    # Whether to LZ4-compress frame payloads.
    compression_enabled: true

    rotation:
      # Default rotation policy, applied to all tenants unless overridden.
      default:
        # Maximum size per WAL file (e.g., "100MB", "1.5GB").
        max_file_size: "25MB"

        # Maximum log entries per WAL file.
        max_log_entries: 50000

        # Maximum time span per WAL file (e.g., "2 hours", "1h", "30m").
        max_file_duration: "2 hours"

      # Per-tenant overrides (uncomment and adjust as needed):
      # certstream:
      #   max_file_size: "100MB"
      #   max_log_entries: 50000

  index:
    retention:
      # Default retention policy, applied to all tenants unless overridden.
      default:
        # Maximum number of index files to retain.
        max_files: 1000

        # Maximum total size of all index files (e.g., "1GB", "500MB").
        max_total_size: "32GB"

        # Maximum age of index files (e.g., "7 days", "1 week", "168h").
        max_age: "7 days"

      # Per-tenant overrides (uncomment and adjust as needed):
      # certstream:
      #   max_age: "30 days"
      #   max_total_size: "50GB"

  catalog:
    # Number of SFST entries accumulated in the per-tenant in-memory
    # accumulator before it rotates into an immutable catalog file.
    rotation_count: 10

# Traces tuning (same shape as logs). The traces pipeline is always built;
# real traces ingestion/indexing is experimental and not yet implemented.
traces:
  wal:
    crc_enabled: true
    compression_enabled: true
    rotation:
      default:
        max_file_size: "25MB"
        max_log_entries: 50000
        max_file_duration: "2 hours"

  index:
    retention:
      default:
        max_files: 1000
        max_total_size: "32GB"
        max_age: "7 days"

  catalog:
    rotation_count: 10
