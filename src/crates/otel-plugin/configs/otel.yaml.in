# OpenTelemetry Plugin Configuration
# This file configures the OpenTelemetry metrics and logs ingestion for Netdata
#
# To customize, run: edit-config otel.yaml
# Only include the fields you want to change — missing fields keep their defaults.

endpoint:
  # gRPC endpoint to listen on for OpenTelemetry data
  path: "127.0.0.1:4317"

  # Path to TLS certificate file (enables TLS when provided)
  tls_cert_path: null

  # Path to TLS private key file (required when TLS certificate is provided)
  tls_key_path: null

  # Path to TLS CA certificate file for client authentication (optional)
  tls_ca_cert_path: null

metrics:
  # Directory with configuration files for mapping OTEL metrics to Netdata charts
  chart_configs_dir: @configdir_POST@/otel.d/v1/metrics

  # Collection interval in seconds (1–3600). Defines the Netdata chart update frequency.
  interval_secs: 10

  # Grace period in seconds. After the last data point, the plugin waits this long
  # before gap-filling. When interval_secs is overridden, this auto-derives as
  # 5 * interval_secs unless explicitly set.
  grace_period_secs: 60

  # Expiry duration in seconds. Charts with no data for this long are removed.
  expiry_duration_secs: 900

  # Maximum number of new charts that can be created per gRPC request.
  # Limits cardinality explosion from high-cardinality label combinations.
  max_new_charts_per_request: 100

# Directory where OpenTelemetry logs and traces are stored.
# Must be an absolute path.
base_dir: @logdir_POST@/otel/v2

storage:
  # Upload data to remote object storage, in addition to keeping it on local
  # disk. One backend is shared by logs and traces.
  enabled: false

  # NEVER put credentials in this file or in the URI below. Credentials are
  # read from the netdata process environment and the standard cloud
  # locations — for S3: AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY,
  # ~/.aws/credentials, or an attached instance role (nothing to configure).
  # To pass environment variables to the netdata service, use a root-only
  # systemd EnvironmentFile.

  # Remote storage location. The scheme selects the backend (fs, s3);
  # non-secret backend options go in the query string. Examples:
  #   fs:///var/lib/netdata/otel/remote
  #   s3://bucket/prefix?region=us-east-1
  #   s3://bucket/prefix?region=us-east-1&endpoint=https://minio.example:9000
  uri: "fs://@logdir_POST@/otel/v2/remote"

  # Data deleted from local disk by retention but still in remote storage is
  # fetched back into a bounded local cache when a query needs it. Cap for
  # that cache:
  read_cache_max_size: "1GB"

auth:
  # Require senders to identify a tenant via the X-Scope-OrgID gRPC header.
  # When disabled, all data belongs to a single "default" tenant.
  # Applies to logs and traces; metrics have no tenants.
  enabled: false

logs:
  rotation:
    # Incoming logs are appended to a current file; a new file starts when
    # any of these limits is reached. Size/entry limits are checked as requests
    # arrive; max_file_duration also seals an idle file with no new requests
    # (checked by a background sweep, so a quiet stream still rotates on time).
    default:
      max_file_size: "25MB"
      max_log_entries: 50000
      max_file_duration: "15 minutes"

    # Per-tenant overrides (any subset of the fields above):
    # my-tenant:
    #   max_file_size: "100MB"

  retention:
    # How much log data to keep on local disk; the oldest files are deleted
    # when any of these limits is exceeded.
    #
    # `horizon` is separate: it is how long the small catalog (index) files that
    # map uploaded data are kept — the depth of the queryable remote archive,
    # independent of local data retention. It MUST exceed max_age (by more than a
    # day), or the plugin refuses to start: a catalog must outlive the data files
    # it indexes. Catalogs are tiny (~KB), so a long horizon costs little.
    default:
      max_files: 100000
      max_total_size: "1GB"
      max_age: "7 days"
      horizon: "2 years"

    # Per-tenant overrides (any subset of the fields above):
    # my-tenant:
    #   max_age: "30 days"

  catalog:
    # A catalog (index) file is written when its accumulator reaches
    # rotation_count entries OR has been open for rotation_period, whichever
    # comes first (plus a flush on clean shutdown). The time trigger bounds how
    # long a quiet host's uploaded data stays uncataloged.
    rotation_count: 10
    rotation_period: "15 minutes"

  ingest:
    # Reject log records whose timestamp falls outside this window, checked per
    # record. Rejections are reported to the sender via OTLP partial_success;
    # in-window records in the same request are still stored. This guards
    # against clock-skewed or bulk-backfilled data that would otherwise distort
    # retention and pin local disk.
    # Reject records older than this (measured from the record's resolved timestamp):
    max_age: "24 hours"
    # Reject records dated more than this far in the future (clock-skew tolerance).
    # A very small value (e.g. "0s") rejects any record even a nanosecond ahead
    # of this agent's clock — including ordinary sender clock skew — so keep some
    # tolerance unless that is specifically what you want.
    future_skew: "10 minutes"
