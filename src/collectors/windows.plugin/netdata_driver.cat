;
; Netdata MSR Driver Catalog File
;
; This file documents the driver components for the Netdata Windows collector.
; The actual .cat file for driver signing is generated during the build process
; using the Windows Driver Kit (WDK) tools.
;

[CatalogHeader]
Name=netdata_driver.cat
CatalogVersion=2
HashAlgorithm=SHA256
PCAT32=1

[Files]
netdata_driver.sys=Driver for reading Model Specific Registers (MSR) on Windows
