        },
        "context_prefix": {
          "$ref": "#/$defs/string_list"
        },
        "context_prefix_exclude": {
          "$ref": "#/$defs/string_list"
        },
        "collect_plugin": {
          "$ref": "#/$defs/string_list"
        },
        "chart_library": {
          "$ref": "#/$defs/chart_library"
        },
        "group_by": {
          "$ref": "#/$defs/string_list"
        },
        "group_by_label": {
          "$ref": "#/$defs/string_list"
        },
        "aggregation_method": {
          "type": "string",
          "enum": [
            "avg",
            "max",
            "min",
            "sum"
