          "pattern": "^[a-zA-Z0-9_.-]+$"
        },
        "priority": {
          "type": "integer"
        },
        "families": {
          "$ref": "#/$defs/families"
        },
        "tooltip": {
          "$ref": "#/$defs/non_empty_string"
        },
        "menu_pattern": {
          "$ref": "#/$defs/non_empty_string"
        },
        "hide_sub_icon": {
          "type": "boolean"
        },
        "force_visibility": {
          "type": "boolean"
        },
        "fallback_icon": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_.-]+$"
        },
        "include_grand_parents": {
          "type": "boolean"
        },
        "properties": {
          "$ref": "#/$defs/properties"
        },
        "section_filters": {
          "type": "object"
        },
        "dyncfg": {
          "type": "object"
        },
        "contexts": {
